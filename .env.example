# ── LLM Provider ────────────────────────────────────────
# Options: openai | anthropic | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# For Ollama (local): set base URL and model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── ASR Provider ─────────────────────────────────────────
# Options: deepgram | whisper
ASR_PROVIDER=deepgram
DEEPGRAM_API_KEY=...
# For local Whisper fallback
WHISPER_MODEL_SIZE=base  # tiny | base | small | medium | large

# ── TTS Provider ─────────────────────────────────────────
# Options: openai | elevenlabs | kokoro
TTS_PROVIDER=openai
# OPENAI_API_KEY already set above
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Server Settings ───────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ── Pipeline Tuning ───────────────────────────────────────
# Temporal Alignment Buffer
TAB_SPEECH_RATE_TOKENS_PER_SEC=8.5
TAB_HIGH_WATER_SEC=0.15
TAB_LOW_WATER_SEC=0.05

# Adaptive Turn-Taking Scheduler
ATTS_EPOCH_MS=50
ATTS_MARGIN_MS=100
ATTS_LEAKY_BUCKET_RATE=1.0   # tokens per epoch
ATTS_LEAKY_BUCKET_BURST=5

# AQAL
AQAL_BUCKET_CAPACITY=30
AQAL_BASE_LEAK_RATE=0.05     # tokens per ms

# ── Observability ─────────────────────────────────────────
PROMETHEUS_PORT=9090
ENABLE_OTEL=false
OTEL_ENDPOINT=http://localhost:4317

# ── Twilio Integration ─────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp sender (Twilio sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Public URL Twilio can reach (use ngrok for local dev: ngrok http 8000)
# Set to your deployed domain in production
PUBLIC_BASE_URL=https://your-ngrok-id.ngrok.io

# Twilio phone number for voice calls (buy one in Twilio Console)
TWILIO_PHONE_NUMBER=+15005550006

# ── Waitlist ───────────────────────────────────────────────
# Email address to receive signup notifications
NOTIFY_EMAIL=fortheloveofai082@gmail.com

# Gmail App Password (NOT your main Gmail password)
# Generate at: myaccount.google.com/security → App Passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

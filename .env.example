# OmniVoice configuration
# Copy to .env and fill in your values, or run: python setup_env.py

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic        # anthropic | openai | ollama | openrouter

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise and conversational.

# ── ASR ──────────────────────────────────────────────────────────────────────
ASR_PROVIDER=whisper           # whisper | deepgram
WHISPER_MODEL_SIZE=base        # tiny | base | small

DEEPGRAM_API_KEY=

# ── TTS ──────────────────────────────────────────────────────────────────────
TTS_PROVIDER=edge              # edge | elevenlabs | openai
EDGE_TTS_VOICE=en-US-AriaNeural

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

OPENAI_TTS_VOICE=alloy

# ── WhatsApp / Twilio ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Tunnel ────────────────────────────────────────────────────────────────────
TUNNEL_PROVIDER=cloudflared    # cloudflared | ngrok
NGROK_AUTH_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
PUBLIC_URL=                    # set automatically by start.py
